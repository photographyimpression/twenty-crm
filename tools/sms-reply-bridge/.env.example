# SMS reply bridge configuration. Copy to .env, fill in real values,
# chmod 600. The bridge runs as the `postfix` user via the pipe
# transport, so .env must be readable by that user (or the bridge user
# you launch it as; see master.cf for the `user=` flag).

# Telnyx API. Required unless TELNYX_DRY_RUN=true.
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=+15142702784
TELNYX_MESSAGING_PROFILE_ID=

# Twenty CRM API. Optional — if set, the bridge will log each outbound
# SMS into the CRM so the conversation thread in the SMS Inbox shows
# the reply Moshe sent from Outlook. Leave blank to skip CRM logging.
#
# TWENTY_API_TOKEN must match SMS_BRIDGE_AUTH_TOKEN in the Twenty
# server's environment. We use a dedicated shared secret rather than a
# user JWT so it never expires.
TWENTY_API_URL=https://crm.impressionphotography.ca
TWENTY_API_TOKEN=

# HMAC secret for the plus-addressing reply token. MUST match
# SMS_REPLY_TOKEN_SECRET in the Twenty server's environment, otherwise
# the bridge will reject every reply as forged. If not set, falls back
# to TELNYX_API_KEY on both sides (acceptable single-tenant default).
SMS_REPLY_TOKEN_SECRET=

# Authorization. The bridge ONLY accepts mail whose From header
# matches this address (case-insensitive). Additional defense: SPF and
# DKIM must both pass according to the Authentication-Results header.
ALLOWED_SENDER=moshe@impressionphotography.ca

# When true, the bridge logs what it WOULD send to Telnyx but does NOT
# actually call the API. Use during integration tests so we never text
# a real number by accident.
TELNYX_DRY_RUN=false

# Skip SPF/DKIM enforcement. ONLY for local testing — never set in
# production. Defaults to false.
SKIP_AUTH_HEADER_CHECK=false

# Audit log path. The bridge appends one JSON line per processed email.
AUDIT_LOG_PATH=/var/log/sms-reply-bridge.log
