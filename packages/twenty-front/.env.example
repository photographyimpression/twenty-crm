REACT_APP_SERVER_BASE_URL=http://localhost:3000
VITE_BUILD_SOURCEMAP=false

# ———————— Telnyx calling ————————
# Get these from Telnyx portal > SIP Connections > Credentials
# REACT_APP_TELNYX_SIP_USERNAME=your-sip-username
# REACT_APP_TELNYX_SIP_PASSWORD=your-sip-password
# REACT_APP_TELNYX_FROM_NUMBER=+15551234567

# ———————— Optional ————————
# REACT_APP_PORT=3001
# CHROMATIC_PROJECT_TOKEN=
# VITE_ENABLE_SSL=false
# VITE_HOST=localhost.com
# SSL_KEY_PATH="./certs/your-cert.key"
# SSL_CERT_PATH="./certs/your-cert.crt"
# IS_DEBUG_MODE=false